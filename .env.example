# Horus environment configuration
# Copy to .env and fill in values:  cp .env.example .env

# Runtime
HORUS_ROOT=
HORUS_ENV=development
PYTHONPATH=

# OpenAI (required for RCM when not using mocks)
OPENAI_API_KEY=

# Optional module-specific keys
AGENT_API_KEY=
SPECIAL_API_KEY=

# Security
ENABLE_API_KEY_VALIDATION=true

# Mock servers (local integration)
MOCK_WEBSITE_HOST=127.0.0.1
MOCK_WEBSITE_PORT=9000
MOCK_OPENAI_HOST=127.0.0.1
MOCK_OPENAI_PORT=8000
RLA_HOST=127.0.0.1
RLA_PORT=3781
OCM_HOST=127.0.0.1
OCM_PORT=8082

# Service ports (defaults — override if needed)
CCU_HEALTH_PORT=11489
RLA_HEALTH_PORT=3781
RCM_HEALTH_PORT=8002
TPP_HEALTH_PORT=8004
TD_HEALTH_PORT=8003
JFA_HEALTH_PORT=8001
OCM_HEALTH_PORT=8082

# Database (optional)
DATABASE_URL=
